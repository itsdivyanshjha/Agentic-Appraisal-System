# ===========================================
# APAS Ingestion Pipeline — Environment Config
# ===========================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# LlamaParse API Key (from https://cloud.llamaindex.ai)
# If left empty, pipeline falls back to PyMuPDF automatically
LLAMA_CLOUD_API_KEY=

# OpenRouter API Key (for LLM-assisted metadata extraction)
# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=
# EXTRACTION_MODEL=openai/gpt-4o-mini

# --- Optional overrides (defaults work out of the box) ---
# SOURCE_DOCS_DIR=./source_documents/
# REFERENCE_DOCS_DIR=./reference_documents/
# CHROMA_PERSIST_DIR=./chroma_db/
# EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
# EMBEDDING_DEVICE=cpu
# LOG_LEVEL=INFO
